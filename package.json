{
  "name": "excel-suradnice-script",
  "version": "0.1.0",
  "description": "Desktop utility for formatting Excel coordinates",
  "main": "build/main.js",
  "author": "",
  "license": "MIT",
  "scripts": {
    "dev": "npm run build:ts && electron .",
    "build:ts": "tsc -p tsconfig.json && node scripts/copy-static.mjs",
    "build": "npm run build:ts",
    "test": "npm run build:ts && node --test build/**/*.test.js",
    "dist:win": "npm run build && electron-builder --win portable zip --x64"
  },
  "devDependencies": {
    "@types/node": "^22.15.17",
    "electron": "^35.2.0",
    "electron-builder": "^24.13.3",
    "typescript": "^5.8.3"
  },
  "build": {
    "appId": "com.ggxc3.excelsuradnicescript",
    "productName": "ExcelSuradniceScript",
    "directories": {
      "buildResources": "assets",
      "output": "release"
    },
    "files": [
      "build/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "requestedExecutionLevel": "asInvoker",
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  },
  "dependencies": {
    "@e965/xlsx": "^0.20.3"
  }
}
